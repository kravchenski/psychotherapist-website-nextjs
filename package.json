{
  "name": "psychotherapist-website",
  "version": "0.1.1",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "export": "bun scripts/export-static.cjs",
    "build-export": "bun run build && bun run export",
    "start": "bun server.js",
    "lint": "eslint"
  },
  "browserslist": {
    "production": [
      "chrome >= 111",
      "edge >= 111",
      "firefox >= 111",
      "safari >= 16.4"
