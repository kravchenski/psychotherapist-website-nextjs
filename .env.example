# Copy this file to `.env.local` for local development.
# Keep real secrets only in `.env.local`, not in git.

# Admin credentials for the custom login page
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_SESSION_MAX_AGE_SECONDS=7200

# Force Tina to use local mode (no Tina Cloud required)
TINA_PUBLIC_IS_LOCAL=true

# Optional Tina Cloud settings
# NEXT_PUBLIC_TINA_CLIENT_ID=your-client-id
# TINA_TOKEN=your-tina-token
